# Admin Tropicale — env vars

# Credentials for /admin-tropicale/login.
# Generate ADMIN_PASSWORD_HASH locally with:
#   node -e "require('bcryptjs').hash(process.argv[1], 10).then(console.log)" 'PASSWORD_HERE'
# IMPORTANT: bcrypt hashes contain `$` which @next/env interprets as variable refs
# and truncates the value. Escape each `$` with a backslash: `\$2b\$10\$...`
# (do the same for any value containing `$`).
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# JWT signing secret for the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# GitHub PAT with `contents:write` on this repo. Used to commit JSON + image edits from the admin.
# Fine-grained PAT scoped to the single repo is recommended.
GITHUB_TOKEN=
GITHUB_OWNER=lollo-santucci
GITHUB_REPO=roma-tropicale
GITHUB_BRANCH=main
